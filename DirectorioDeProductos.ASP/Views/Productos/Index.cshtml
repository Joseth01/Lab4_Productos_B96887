@model IEnumerable<DirectorioDeProductos.ASP.Models.Producto>

@{
    ViewData["Title"] = "Index";
}

<h1 class="mb-4">Lista de Productos</h1>

<p>
    <a asp-action="Crear" class="btn btn-primary">Nuevo Producto</a>
</p>

@if (!Model.Any())
{
    <div class="alert alert-info text-center">
        No hay productos registrados.
    </div>
}
else
{
    <div class="row">
        @foreach (var item in Model)
        {
            <div class="col-md-6 mb-3">
                <div class="card shadow h-100">
                    <div class="card-body">

                        <h5 class="card-title">@item.Nombre</h5>

                        <p class="card-text">
                            <strong>Id:</strong> @item.Id <br />
                            <strong>Precio:</strong> @item.Precio.ToString("C") <br />
                            <strong>Categoría:</strong> @item.Categoria
                        </p>

                        <div class="d-flex justify-content-between">
                            <a asp-action="Editar" asp-route-id="@item.Id" class="btn btn-warning btn-sm">Editar</a>
                            <a asp-action="Detalles" asp-route-id="@item.Id" class="btn btn-info btn-sm">Detalles</a>
                            <a asp-action="Eliminar" asp-route-id="@item.Id" class="btn btn-danger btn-sm">Eliminar</a>
                        </div>

                    </div>
                </div>
            </div>
        }
    </div>
}